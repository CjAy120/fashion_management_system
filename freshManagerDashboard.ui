        <string notr="true">QTableView {
    background-color: rgba(20, 30, 100, 180);
    alternate-background-color: rgba(30, 45, 130, 180);
    border: 1px solid rgba(192, 192, 192, 0.3);
    gridline-color: rgba(192, 192, 192, 0.2);
