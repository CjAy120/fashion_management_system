    selection-color: #ffffff;
    color: white;
    font: 10pt &quot;Segoe UI&quot;;
    border-radius: 8px;
}

QHeaderView::section {
    background-color: rgba(10, 15, 80, 220);
    color: #C0C0C0;
    padding: 6px;
    border: none;
    font: bold 10pt &quot;Segoe UI&quot;;
}

QTableView::item {
    border: none;
    padding: 4px;
}

QTableView QTableCornerButton::section {
    background-color: rgba(10, 15, 80, 220);
    border: none;
}

QScrollBar:vertical {
    border: none;
    background: rgba(20, 30, 100, 120);
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: rgba(192, 192, 192, 0.5);
    border-radius: 5px;
}

QScrollBar:horizontal {
    border: none;
    background: rgba(20, 30, 100, 120);
    height: 10px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: rgba(192,192,192,0.5);
    border-radius: 5px;
}

QTableView::item:hover {
    background-color: rgba(255,255,255,0.08);
}</string>
