        <property name="styleSheet">
         <string notr="true">QComboBox {
    background-color: rgba(255, 255, 255, 25);
    border: 1px solid rgba(192, 192, 192, 0.5);
    border-radius: 6px;
    color: white;
    padding: 4px 8px;
    min-height: 20px;
}

QComboBox:hover {
    border: 1px solid rgba(192, 192, 192, 0.8);
    background-color: rgba(255, 255, 255, 40);
}

QComboBox:focus {
    border: 1px solid rgba(100, 140, 255, 0.8);
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 24px;
    border-left: 1px solid rgba(192, 192, 192, 0.3);
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
    background-color: rgba(255, 255, 255, 15);
}

QComboBox::down-arrow {
    width: 10px;
    height: 10px;
    image: none;
    border-left: 2px solid rgba(192, 192, 192, 0.8);
    border-bottom: 2px solid rgba(192, 192, 192, 0.8);
}

QComboBox QAbstractItemView {
    background-color: rgba(13, 22, 117, 220);
    border: 1px solid rgba(192, 192, 192, 0.3);
    border-radius: 6px;
    color: white;
    selection-background-color: rgba(68, 102, 221, 180);
    selection-color: white;
    outline: none;
    padding: 4px;
}

QComboBox QAbstractItemView::item {
    min-height: 28px;
    padding: 4px 8px;
    border-radius: 4px;
}

QComboBox QAbstractItemView::item:hover {
    background-color: rgba(255, 255, 255, 40);
}</string>
        </property>
       </widget>
