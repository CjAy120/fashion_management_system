       <property name="styleSheet">
        <string notr="true">QTableView {
    background-color: #ffffff;
    alternate-background-color: #f4f6fa;
    border: none;
    gridline-color: #e0e0e0;
    selection-background-color: #0d1675;  
    selection-color: #ffffff;
    font: 10pt &quot;Segoe UI&quot;;
}

QHeaderView::section {
    background-color: #0d1675; 
    color: #ffffff;          
    padding: 6px;
    border: none;
    font: bold 10pt &quot;Segoe UI&quot;;
}

QTableView::item {
    border: none;
    padding: 4px;
}

QTableView QTableCornerButton::section {
    background-color: #0d1675;
    border: none;
	border-top-left-radius: 10px; 
}

QScrollBar:vertical {
    border: none;
    background: #f0f0f0;
    width: 10px;
    margin: 0px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #0d1675;   
    min-height: 30px;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #C0C0C0;   
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

QScrollBar:horizontal {
    border: none;
    background: #f0f0f0;
    height: 10px;
    margin: 0px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: #0d1675;
    min-width: 30px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal:hover {
    background: #e60023;   
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    border: none;
    background: none;
    width: 0px;
}
</string>
